<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Adaptive Study Planner</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: #000;
    color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    padding: 32px 16px;
    line-height: 1.5;
  }
  .container { max-width: 640px; margin: 0 auto; }
  h1 { font-size: 28px; margin-bottom: 32px; font-weight: 700; }
  .section {
    border: 2px solid;
    border-image: linear-gradient(135deg, #7ec8e3, #a78bfa) 1;
    padding: 24px;
    margin-bottom: 28px;
  }
  .section h2 { font-size: 18px; font-weight: 600; margin-bottom: 16px; }
  label { display: block; font-size: 14px; margin-bottom: 4px; color: #ccc; }
  input, select, textarea {
    display: block;
    width: 100%;
    padding: 10px 12px;
    margin-bottom: 16px;
    background: #111;
    color: #fff;
    border: 1px solid #555;
    font-size: 15px;
    font-family: inherit;
  }
  textarea { min-height: 80px; resize: vertical; }
  select { appearance: auto; }
  button {
    display: block;
    width: 100%;
    padding: 12px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    color: #fff;
    background: linear-gradient(135deg, #7ec8e3, #a78bfa);
    font-family: inherit;
  }
  button:disabled { opacity: 0.4; cursor: default; }
  .row { display: flex; gap: 12px; }
  .row > * { flex: 1; }
  .hidden { display: none; }
  #error {
    background: #3a1111;
    color: #f87171;
    padding: 10px 14px;
    margin-bottom: 20px;
    font-size: 14px;
  }
  #error.hidden { display: none; }
  .badge {
    display: inline-block;
    padding: 4px 14px;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .badge.correct { background: #166534; color: #bbf7d0; }
  .badge.incorrect { background: #7f1d1d; color: #fecaca; }
  .fb-label { font-size: 13px; color: #aaa; margin-bottom: 2px; }
  .fb-text { font-size: 14px; margin-bottom: 14px; }
  .diff { font-size: 12px; color: #a78bfa; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
</style>
</head>
<body>
<div class="container">
  <h1>Adaptive Study Planner</h1>

  <div id="error" class="hidden"></div>

  <div id="setupSection" class="section">
    <h2>Setup</h2>
    <label for="name">Student Name</label>
    <input id="name" placeholder="Your name">
    <label for="topic">Topic</label>
    <input id="topic" placeholder="e.g. Linear Algebra">
    <div class="row">
      <div>
        <label for="skill">Skill Level</label>
        <select id="skill">
          <option value="beginner">Beginner</option>
          <option value="intermediate">Intermediate</option>
          <option value="advanced">Advanced</option>
        </select>
      </div>
      <div>
        <label for="goal">Goal</label>
        <select id="goal">
          <option value="exam">Exam Prep</option>
          <option value="mastery">Mastery</option>
          <option value="speed">Speed</option>
        </select>
      </div>
    </div>
    <button id="startBtn" onclick="startDemo()">Start Demo</button>
  </div>

  <div id="questionSection" class="section hidden">
    <h2>Question</h2>
    <div id="qDiff" class="diff"></div>
    <p id="qText" style="margin-bottom:16px"></p>
    <label for="answer">Your Answer</label>
    <input id="answer" placeholder="Type your answer">
    <label for="reasoning">Reasoning</label>
    <textarea id="reasoning" placeholder="Explain your reasoning…"></textarea>
    <button id="submitBtn" onclick="submitAnswer()">Submit Answer</button>
  </div>

  <div id="feedbackSection" class="section hidden">
    <h2>Feedback</h2>
    <div id="correctBadge" class="badge"></div>
    <div class="fb-label">Explanation</div>
    <p id="explanationText" class="fb-text"></p>
    <div class="fb-label">Reasoning Feedback</div>
    <p id="reasoningText" class="fb-text"></p>
    <button onclick="nextQuestion()">Next Question →</button>
  </div>
</div>

<script>
const API = "http://127.0.0.1:8000";
let userId = null;
let currentQuestion = null;
let storedTopic = "";

function showError(msg) {
  const el = document.getElementById("error");
  el.textContent = msg;
  el.classList.remove("hidden");
}

function clearError() {
  const el = document.getElementById("error");
  el.textContent = "";
  el.classList.add("hidden");
}

async function startDemo() {
  clearError();

  const name = document.getElementById("name").value.trim();
  const topic = document.getElementById("topic").value.trim();
  const skill = document.getElementById("skill").value;
  const goal = document.getElementById("goal").value;

  if (!name || !topic) {
    showError("Name and topic are required.");
    return;
  }

  storedTopic = topic;

  const res = await fetch("http://127.0.0.1:8000/user/create", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      name: name,
      skill_level: skill,
      goal: goal,
      initial_topic: topic
    })
  });

  const data = await res.json();
  if (!res.ok) throw new Error(data.detail || "Failed to create user");

  userId = data.user_id;
  await fetchQuestion();
}
async function fetchQuestion() {
  clearError();

  const res = await fetch("http://127.0.0.1:8000/get_question", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      user_id: userId,
      topic: storedTopic
    })
  });

  const data = await res.json();
  if (!res.ok) throw new Error(data.detail || "Failed to get question");

  currentQuestion = data;
  document.getElementById("qText").textContent = data.question || "";
  document.getElementById("qDiff").textContent = data.difficulty || "";
}

async function submitAnswer() {
  clearError();

  const answer = document.getElementById("answer").value.trim();
  const reasoning = document.getElementById("reasoning").value.trim();

  if (!answer) {
    showError("Please enter an answer.");
    return;
  }

  const res = await fetch("http://127.0.0.1:8000/submit_answer", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      user_id: userId,
      exercise_id: currentQuestion.exercise_id,
      user_answer: answer,
      user_reasoning: reasoning,
      response_time: 10.0,
      hints_used: 0
    })
  });

  const fb = await res.json();
  if (!res.ok) throw new Error(fb.detail || "Submit failed");

  document.getElementById("correctBadge").textContent =
    fb.is_correct ? "✓ Correct" : "✗ Incorrect";

  document.getElementById("explanationText").textContent = fb.explanation || "";
  document.getElementById("reasoningText").textContent = fb.feedback || "";
}

function nextQuestion() {
  fetchQuestion();
}
</script>
